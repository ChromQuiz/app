{
  "rules": {
    "projects": {
      "$projectId": {
        "publicSettings": {
          ".read": "auth != null",
          ".write": "auth != null"
        },
        "entries": {
          ".read": "auth != null",
          ".write": "auth != null",
          ".indexOn": ["entryNumber", "emailHash"],
          "$entryId": {
            ".validate": "newData.hasChildren(['uuid', 'entryNumber', 'emailHash', 'status']) && newData.child('uuid').isString() && newData.child('entryNumber').isNumber() && newData.child('emailHash').isString() && newData.child('status').isString()"
          }
        },
        "protected": {
          "$secretHash": {
            ".read": "auth != null",
            ".write": "auth != null"
          }
        },
        "disclosure": {
          ".read": "auth != null",
          ".write": "auth != null",
          "$num": {
            ".validate": "newData.isString() || newData.hasChildren()"
          }
        }
      }
    },
    "feedback": {
      ".read": false,
      ".write": "auth != null && newData.hasChildren(['message']) && newData.child('message').isString() && newData.child('message').val().length <= 2000"
    },
    ".read": false,
    ".write": false
  }
}
